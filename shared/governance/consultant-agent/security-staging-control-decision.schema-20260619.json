{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Consultant Agent Security Staging Control Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "control_id",
    "control_title",
    "control_area",
    "decision",
    "security_reviewer",
    "ops_reviewer",
    "reviewed_at",
    "review_notes",
    "evidence_uri",
    "external_config_required",
    "external_config_status",
    "permitted_actions",
    "blocked_actions",
    "conditions",
    "production_impact",
    "provider_call_boundary",
    "live_kb_ingestion",
    "manual_review_boundary",
    "secret_redaction_boundary"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^SEC-STG-[0-9]{3}-20260619$"
    },
    "control_id": {
      "type": "string",
      "pattern": "^SEC-STG-[0-9]{3}$"
    },
    "control_title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160
    },
    "control_area": {
      "type": "string",
      "enum": [
        "network_boundary",
        "secret_storage",
        "auth",
        "audit_storage",
        "audit_retention",
        "rate_limit",
        "rollback",
        "rbac"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "pending_review",
        "approved",
        "rejected",
        "needs_discussion"
      ]
    },
    "security_reviewer": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 80
    },
    "ops_reviewer": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 80
    },
    "reviewed_at": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "review_notes": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 1000
    },
    "evidence_uri": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500
    },
    "external_config_required": {
      "type": "boolean"
    },
    "external_config_status": {
      "type": "string",
      "enum": [
        "not_configured",
        "configured_externally",
        "not_required"
      ]
    },
    "permitted_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 120
      },
      "uniqueItems": true
    },
    "blocked_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 160
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 240
      },
      "uniqueItems": true
    },
    "production_impact": {
      "const": "production unchanged"
    },
    "provider_call_boundary": {
      "const": "no KB provider call"
    },
    "live_kb_ingestion": {
      "const": "no live KB ingestion"
    },
    "manual_review_boundary": {
      "const": "security and operations approval required before shared staging"
    },
    "secret_redaction_boundary": {
      "const": "do not store secret values, raw tokens, passwords, private keys, or private contact details in this repository"
    }
  }
}
